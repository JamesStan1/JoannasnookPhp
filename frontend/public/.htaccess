<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Do not re-rewrite if already pointing at api/index.php
    RewriteRule ^api/index\.php$ - [L]

    # Serve uploaded files directly — never route through index.php
    RewriteRule ^api/uploads/ - [L]

    # Route all /api/* requests directly to api/index.php
    # (more reliable on shared hosting than relying on the child .htaccess)
    RewriteRule ^api(/.*)?$ api/index.php [QSA,L]

    # Serve existing files and directories directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirect everything else to Vue SPA entry point
    RewriteRule ^ index.html [L]
</IfModule>
